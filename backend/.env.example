APP_NAME="Tchokos SARL"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
# URL publique de l'API Laravel.
APP_URL=http://localhost:8000
# URL du frontend Next.js — utilisée pour la config CORS (config/cors.php).
FRONTEND_URL=http://localhost:3000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# En prod (Railway) : inclure "stderr" est nécessaire pour voir les erreurs
# dans "View logs" — le fichier storage/logs/laravel.log n'est pas visible
# depuis le dashboard, seul le stdout/stderr du process l'est.
LOG_STACK=single,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Base de données ---------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tchokos
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Garder "database" pour traiter e-mails et push de façon asynchrone (§2.2, §5 du cahier des charges).
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- E-mail (notifications transactionnelles, §5.2) ---------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="contact@tchokos.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Web Push (VAPID, sans Firebase) -------------------------------------
# Générer avec : php artisan webpush:vapid-keys
VAPID_SUBJECT="mailto:admin@tchokos.com"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Stockage médias (S3-compatible / Cloudinary, §2.3) ------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- WhatsApp (commande & paiement assisté, §5.1 / §6.3) -----------------
# Numéro du service client au format international, ex: 2376XXXXXXXX.
WHATSAPP_PHONE_NUMBER=
# Si l'API WhatsApp Business est utilisée (option avancée, §5.1).
WHATSAPP_BUSINESS_API_TOKEN=
WHATSAPP_BUSINESS_PHONE_ID=

# --- Paiement : Orange Money (§6.1) --------------------------------------
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_API_USERNAME=
ORANGE_MONEY_API_PASSWORD=

# --- Paiement : Mobile Money / MTN MoMo (§6.2) ---------------------------
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_SUBSCRIPTION_KEY=

# --- Paiement : agrégateur local (optionnel, §6.4) -----------------------
PAYMENT_AGGREGATOR_API_KEY=
PAYMENT_AGGREGATOR_WEBHOOK_SECRET=

# Tant qu'aucune clé Orange Money / MTN MoMo ci-dessus n'est renseignée, les
# providers basculent sur un mode sandbox simulé (flux initiate → webhook →
# commande payée testable de bout en bout, sans appel réel à un opérateur).
SANDBOX_PAYMENT_WEBHOOK_SECRET=

# Secret partagé avec le frontend (app/api/revalidate) pour invalider le cache
# ISR dès qu'un produit/catégorie/média/promo change dans l'admin. Même valeur
# des deux côtés (backend .env et frontend .env.local).
REVALIDATE_SECRET=

# --- Notifications push : Web Push (VAPID) / FCM (§2.4, §5.3) ------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:contact@tchokos.com"
FCM_SERVER_KEY=

VITE_APP_NAME="${APP_NAME}"
